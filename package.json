{
  "name": "nextjs",
  "version": "0.1.0",
  "description": "Flight Information Display System for Tivat Airport",
  "author": "Tivat Airport",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "npm run db:init && next dev",
    "build": "next build",
"postbuild": "node scripts/postbuild.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:init": "node scripts/init-db.js",
    "dev:no-db": "next dev",
    "electron": "npm run build && electron .",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:prod": "npm run build && cross-env NODE_ENV=production electron .",
    "electron:checkin04": "node -e \"require('fs').writeFileSync('settings.ini', '[app]\\npath=checkin/04\\nfullscreen=true\\nkiosk=true')\" && npm run electron",
    "electron:gate03": "node -e \"require('fs').writeFileSync('settings.ini', '[app]\\npath=gate/03\\nfullscreen=true\\nkiosk=true')\" && npm run electron",
    "electron:checkin07": "node -e \"require('fs').writeFileSync('settings.ini', '[app]\\npath=checkin/07\\nfullscreen=true\\nkiosk=true')\" && npm run electron",
    "electron:kill": "taskkill /F /IM electron.exe",
    "dist:win": "npm run build && electron-builder build --win --x64",
    "dist:win32": "npm run build && electron-builder build --win --ia32",
    "dist:both": "npm run build && electron-builder build --win --x64 --ia32"
  },
  "build": {
    "appId": "com.tivatairport.fids-tiv",
    "productName": "FIDS TIV",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "loading.html",
      "node_modules/**/*",
      "settings.ini"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FIDS TIV",
      "runAfterFinish": false
    },
    "extraResources": [
      {
        "from": "node.exe",
        "to": "../node.exe",
        "filter": ["**/*"]
      },
      {
        "from": ".next/standalone/",
        "to": "app",
        "filter": ["**/*"]
      },
      {
        "from": ".next/standalone/public/",
        "to": "app/public",
        "filter": ["**/*"]
      },
      {
        "from": "data/",
        "to": "data",
        "filter": ["**/*"]
      }
    ]
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@supabase/supabase-js": "^2.58.0",
    "@types/node": "20.6.2",
   "@types/react": "^18.3.0",
"@types/react-dom": "^18.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "eslint": "8.49.0",
    "eslint-config-next": "13.5.1",
    "ini": "^6.0.0",
    "lucide-react": "^0.446.0",
    "next": "14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.2.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.8",
    "electron": "21.3.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "wait-on": "^7.2.0"
  }
}